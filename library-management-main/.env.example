# .env.example — copy to .env and fill in your values
# This file is safe to commit. Never commit .env (it is gitignored).

# PostgreSQL
POSTGRES_USER=libraryuser
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=library_db

# FastAPI
SECRET_KEY=changeme_secret_key_at_least_32_chars_long
ADMIN_EMAIL=admin@library.university.edu
ADMIN_PASSWORD=changeme_admin_password

# Frontend (used by Vite)
VITE_API_URL=http://localhost:8000
